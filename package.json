{
  "name": "septa-map",
  "version": "1.0.0",
  "description": "Display Live SEPTA bus &amp; trolley positions.",
  "main": "index.ts",
  "dependencies": {
    "axios": "^0.19.0",
    "body-parser": "^1.19.0",
    "express": "^4.17.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "concurrently": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.103.0"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "tsx index.ts",
    "dev": "concurrently \"PORT=5050 tsx index.ts\" \"cd client && npm run start\"",
    "build": "cd client && npm install && npm run build",
    "cf:dev": "npm run build && wrangler pages dev",
    "cf:deploy": "npm run build && wrangler pages deploy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scotteratigan/septa-map.git"
  },
